# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=3088
# Image Docker (CI → ghcr.io/sannier3/iso-watcher). :latest ou 0.2.0 — pas de tag sha-*
ISO_WATCHER_IMAGE=ghcr.io/sannier3/iso-watcher:latest
INTRANET_SHARED_TOKEN=change-ce-token-long-et-aleatoire
# Derrière nginx/Cloudflare : URL exacte du site (pas * si cookies de session)
# Ex. CORS_ORIGIN=https://iso.example.com
CORS_ORIGIN=*
PUBLIC_UI_ENABLED=true

# --- Sécurité (sessions cookie HttpOnly, anti brute-force, CSP) ---
# true derrière reverse proxy (nginx, Cloudflare) — lit X-Forwarded-For
TRUST_PROXY=false
# true en HTTPS (prod) ; false en http://127.0.0.1 pour tests locaux
UI_SESSION_COOKIE_SECURE=false
UI_SESSION_COOKIE_SAME_SITE=lax
UI_SESSION_MAX_AGE_MS=43200000
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MS=900000
LOGIN_LOCKOUT_MS=900000
API_RATE_LIMIT_MAX=300
API_RATE_LIMIT_WINDOW_MS=60000
# true si TLS terminé sur le proxy (HSTS)
SECURITY_HSTS_ENABLED=false
CSP_REPORT_ONLY=false
# Actions sur la page publique (/) : scan, vérification liens (santé toujours via /health)
PUBLIC_UI_ALLOW_ACTIONS=false
# true = session opérateur automatique (réseau local uniquement)
PUBLIC_UI_ACTIONS_AUTO_AUTH=false
# true = ui-session / ui-login refusés depuis Internet (RFC1918 + loopback)
PUBLIC_UI_RESTRICT_TO_PRIVATE_NETWORK=true

# --- Console d'administration web (/admin) ---
ADMIN_UI_ENABLED=true
# true = mot de passe obligatoire (recommandé si exposé au-delà du LAN)
ADMIN_UI_AUTH_REQUIRED=true
# Si AUTH_REQUIRED=true : mot de passe admin (sinon = INTRANET_SHARED_TOKEN)
ADMIN_UI_PASSWORD=
# true = connexion admin refusée depuis Internet
ADMIN_UI_RESTRICT_TO_PRIVATE_NETWORK=true

# --- Catalogue de configurations ISO (presets GitHub) ---
# URL raw du catalogue (défaut : branche main du dépôt ISO-WATCHER)
# PRESETS_CATALOG_URL=https://raw.githubusercontent.com/sannier3/ISO-WATCHER/main/presets/catalog.json
# true = utiliser le cache GitHub (data/presets-catalog-cache.json) plutôt que le catalogue embarqué
PRESETS_PREFER_REMOTE=false
# Génération du catalogue : intranet (sélection ISO OK) ou npm run build-presets (bootstrap initial uniquement)

# --- Base de données (sqlite par défaut, mysql optionnel) ---
DB_DRIVER=sqlite
SQLITE_PATH=./data/iso-watcher.db

# MySQL (uniquement si DB_DRIVER=mysql)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=iso_watcher
MYSQL_PASSWORD=mot-de-passe-mysql
MYSQL_DATABASE=iso_watcher
MYSQL_CONNECTION_LIMIT=10
# MYSQL_ALLOW_EMPTY_PASSWORD=1

# --- Stockage local des ISO (releases connues en base uniquement) ---
STORAGE_ENABLED=false
STORAGE_ROOT=./data/storage
# true = {STORAGE_ROOT}/{distribution}/{iso}/{fichier} — false = {STORAGE_ROOT}/{fichier}
STORAGE_USE_SUBFOLDERS=true
STORAGE_DOWNLOAD_ON_DETECT=true
STORAGE_REPLACE_OLD=true
STORAGE_MAX_PARALLEL_DOWNLOADS=2
STORAGE_DOWNLOAD_TIMEOUT_MS=7200000

# --- Planificateur de scans ---
SCHEDULER_ENABLED=true
SCHEDULER_CRON=0 * * * *
# Au redémarrage Node : interrupt = marquer les scans « running » en interrompu (défaut) ; ignore = ne rien faire
SCAN_STARTUP_RECOVERY=interrupt

# --- Vérification quotidienne des liens (suppression si mort + rapport admin) ---
LINK_CHECK_ENABLED=true
LINK_CHECK_CRON=0 4 * * *
LINK_CHECK_CONCURRENCY=5
LINK_CHECK_REPORT_HOURS=24
ADMIN_EMAIL=admin@example.com
ADMIN_INSTANT_NOTIFY=true

# --- SMTP ---
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_IGNORE_TLS=true
SMTP_REQUIRE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_FROM_NAME=ISO Watcher
SMTP_FROM_ADDRESS=iso-watcher@localhost

# --- Timeouts et limites ---
HTTP_TIMEOUT_MS=30000
FTP_TIMEOUT_MS=30000
MAX_PARALLEL_SOURCES=5
# Logs de scan : 0 = illimité pour la variable concernée
SCAN_MAX_LOG_LINES=2000
SCAN_LOG_EXCERPT_CHARS=32000
SCAN_LOG_MAX_MESSAGE_CHARS=16000
SCAN_LOG_PRUNE_BATCH=200
# debug | info | warn | error — filtre ce qui est enregistré en base (ex. info pour moins de bruit)
SCAN_LOG_MIN_LEVEL=debug
SCAN_LOG_API_DEFAULT_LIMIT=2000
SCAN_LOG_API_MAX_LIMIT=10000

# --- Notifications (Discord / Teams / livraisons) ---
DELIVERY_CRON=*/5 * * * *
DIGEST_DAILY_HOUR=8
MAX_DELIVERY_ATTEMPTS=8
DISCORD_MAX_EMBEDS_PER_MESSAGE=10
DISCORD_MAX_EMBED_TOTAL_CHARS=6000
DISCORD_MAX_MESSAGES_PER_MINUTE=30
TEAMS_MAX_PAYLOAD_BYTES=28672
TEAMS_MAX_REQUESTS_PER_SECOND=4
